{    "name": "edusmart/edusmart-cm",    "type": "project",    "description": "EduSmart Content Management System",    "keywords": ["laravel", "education", "cms"],    "license": "MIT",    "require": {        "php": "^8.2",        "barryvdh/laravel-dompdf": "^2.0",        "laravel/framework": "^11.0",        "laravel/sanctum": "^4.3"    },    "require-dev": {        "phpunit/phpunit": "^11.0",        "laravel/pint": "^1.0"    },    "autoload": {        "psr-4": {            "App\\": "app/",            "Database\\Factories\\": "database/factories/",            "Database\\Seeders\\": "database/seeders/"        }    },    "scripts": {        "post-autoload-dump": [            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",            "@php artisan package:discover --ansi"        ],        "post-root-package-install": [            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""        ],        "post-create-project-cmd": [            "@php artisan key:generate --ansi",            "@php artisan migrate --seed"        ]    },    "config": {        "sort-packages": true,        "allow-plugins": {            "pestphp/pest-plugin": true        }    },    "minimum-stability": "stable",    "prefer-stable": true}